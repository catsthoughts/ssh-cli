{
  "profiles": {
    "dev": {
      "key": {
        "tag": "com.example.sshcli.dev",
        "label": "Dev Key",
        "comment": "dev@mac",
        "public_key_path": "~/.ssh-cli/id_dev.pub",
        "key_source": "secure_enclave"
      },
      "proxy": {
        "address": "127.0.0.1:2222",
        "user": "your-user",
        "known_hosts": "~/.ssh/known_hosts",
        "host_key_policy": "accept-new",
        "insecure_ignore_hostkey": false,
        "use_agent_forwarding": true,
        "connect_timeout_seconds": 10,
        "balance_mode": "failover",
        "retry_attempts": 1,
        "retry_delay_seconds": 2
      },
      "target": {
        "command": "",
        "request_tty": true,
        "forward_ctrl_c": true
      },
      "certificate": {
        "type": "ssh-user",
        "ca_key_path": "~/.ssh-cli/ssh_user_ca",
        "output_path": "~/.ssh-cli/id_dev-cert.pub",
        "auth_cert_path": "~/.ssh-cli/id_dev-cert.pub",
        "identity": "your-user",
        "principals": [
          "your-user"
        ],
        "valid_for": "24h",
        "subject_common_name": "your-user"
      }
    },
    "prod": {
      "key": {
        "tag": "com.example.sshcli.prod",
        "label": "Production Key",
        "comment": "prod@mac",
        "public_key_path": "~/.ssh-cli/id_prod.pub",
        "key_source": "secure_enclave"
      },
      "proxy": {
        "address": "proxy.example.com:2222",
        "user": "your-user",
        "known_hosts": "~/.ssh/known_hosts",
        "host_key_policy": "accept-new",
        "insecure_ignore_hostkey": false,
        "use_agent_forwarding": true,
        "connect_timeout_seconds": 10,
        "balance_mode": "failover",
        "retry_attempts": 2,
        "retry_delay_seconds": 5
      },
      "target": {
        "command": "",
        "request_tty": true,
        "forward_ctrl_c": false
      },
      "certificate": {
        "type": "ssh-user",
        "ca_key_path": "~/.ssh-cli/ssh_user_ca",
        "output_path": "~/.ssh-cli/id_prod-cert.pub",
        "auth_cert_path": "~/.ssh-cli/id_prod-cert.pub",
        "identity": "your-user",
        "principals": [
          "your-user"
        ],
        "valid_for": "8h",
        "subject_common_name": "your-user"
      }
    },
    "prod-ha": {
      "key": {
        "tag": "com.example.sshcli.prod",
        "label": "Production Key",
        "comment": "prod@mac",
        "public_key_path": "~/.ssh-cli/id_prod.pub",
        "key_source": "secure_enclave"
      },
      "proxy": {
        "address": [
          "proxy-1.example.com:2222",
          "proxy-2.example.com:2222",
          "proxy-3.example.com:2222"
        ],
        "user": "your-user",
        "known_hosts": "~/.ssh/known_hosts",
        "host_key_policy": "accept-new",
        "insecure_ignore_hostkey": false,
        "use_agent_forwarding": true,
        "connect_timeout_seconds": 10,
        "balance_mode": "round-robin",
        "retry_attempts": 3,
        "retry_delay_seconds": 3
      },
      "target": {
        "command": "",
        "request_tty": true,
        "forward_ctrl_c": false
      },
      "certificate": {
        "type": "ssh-user",
        "ca_key_path": "~/.ssh-cli/ssh_user_ca",
        "output_path": "~/.ssh-cli/id_prod-cert.pub",
        "auth_cert_path": "~/.ssh-cli/id_prod-cert.pub",
        "identity": "your-user",
        "principals": [
          "your-user"
        ],
        "valid_for": "8h",
        "subject_common_name": "your-user"
      }
    },
    "staging": {
      "key": {
        "tag": "com.example.sshcli.staging",
        "label": "Staging YubiKey",
        "comment": "staging@yubikey",
        "public_key_path": "~/.ssh-cli/id_staging.pub",
        "key_source": "yubikey_piv",
        "yubikey": {
          "slot": "9a"
        }
      },
      "proxy": {
        "address": "proxy-staging.example.com:2222",
        "user": "your-user",
        "known_hosts": "~/.ssh/known_hosts",
        "host_key_policy": "accept-new",
        "insecure_ignore_hostkey": false,
        "use_agent_forwarding": true,
        "connect_timeout_seconds": 10,
        "balance_mode": "failover",
        "retry_attempts": 1,
        "retry_delay_seconds": 5
      },
      "target": {
        "command": "",
        "request_tty": true,
        "forward_ctrl_c": false
      },
      "certificate": {
        "type": "ssh-user",
        "ca_key_path": "~/.ssh-cli/ssh_user_ca",
        "output_path": "~/.ssh-cli/id_staging-cert.pub",
        "auth_cert_path": "~/.ssh-cli/id_staging-cert.pub",
        "identity": "your-user",
        "principals": [
          "your-user"
        ],
        "valid_for": "8h",
        "subject_common_name": "your-user"
      }
    }
  },
  "active_profile": "prod"
}
